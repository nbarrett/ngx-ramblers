#!/usr/bin/env bash
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

find_checkout_root() {
  local dir="$1"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/fly.toml" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

PROJECT_ROOT="$(find_checkout_root "$PWD")" || PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

HASH_FILE="node_modules/.install-hash"

compute_hash() {
  local hasher="sha256sum"
  command -v shasum >/dev/null 2>&1 && hasher="shasum -a 256"
  cat package-lock.json server/package-lock.json 2>/dev/null | $hasher | cut -d' ' -f1
}

needs_install() {
  [ ! -d "node_modules" ] && return 0
  [ ! -f "$HASH_FILE" ] && return 0

  current_hash=$(compute_hash)
  stored_hash=$(cat "$HASH_FILE" 2>/dev/null)

  [ "$current_hash" != "$stored_hash" ] && return 0

  [ ! -x "node_modules/.bin/ts-node" ] && return 0
  [ ! -x "node_modules/.bin/ng" ] && return 0

  return 1
}

if needs_install; then
  echo "Installing dependencies..."
  npm install
  npm install --prefix server
  compute_hash > "$HASH_FILE"
fi

./node_modules/.bin/ts-node server/lib/cli/index.ts "$@"
