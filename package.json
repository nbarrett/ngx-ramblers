{
  "name": "ngx-ramblers",
  "description": "Ramblers groups website framework: https://www.ngx-ramblers.org.uk",
  "version": "2.0.0",
  "license": "ISC",
  "private": true,
  "bin": {
    "ngx-cli": "./bin/ngx-cli"
  },
  "scripts": {
    "dev": "claude-swarm start",
    "stop": "claude-swarm stop",
    "analyze": "webpack-bundle-analyzer dist/ngx-ramblers/stats-es2015.json",
    "build:stats": "ng build --project ngx-ramblers --configuration production --statsJson=true",
    "build": "ng build --project ngx-ramblers --progress --configuration production",
    "clean": "rm -rf node_modules && rm -rf server/node_modules",
    "reinstall": "npm run clean && npm install && npm run postbuild",
    "postinstall": "npm run build:eslint-config --silent",
    "setup:hooks": "bash tools/setup-git-hooks.sh",
    "e2e": "ng e2e",
    "build:eslint-config": "ts-node --project tsconfig.tools.json ./tools/build-eslint-config.ts",
    "lint": "npm run build:eslint-config --silent && eslint --config .eslint-config/eslint.config.js \"projects/ngx-ramblers/**/*.{ts,html}\"",
    "lint:frontend": "npm run lint",
    "lint:server": "npm run build:eslint-config --silent && eslint --config .eslint-config/eslint.config.js \"server/**/*.ts\"",
    "lint:all": "npm run build:eslint-config --silent && eslint --config .eslint-config/eslint.config.js \"projects/ngx-ramblers/**/*.{ts,html}\" \"server/**/*.ts\"",
    "lintfix": "npm run build:eslint-config --silent && eslint --config .eslint-config/eslint.config.js \"projects/ngx-ramblers/**/*.{ts,html}\" --fix",
    "postbuild": "npm install --prefix server",
    "serve": "ng serve --project ngx-ramblers --configuration development --verbose",
    "test": "ng test --project ngx-ramblers --watch=false",
    "test:watch": "ng test --project ngx-ramblers",
    "test:server": "sh -c 'cd server && npm run unit-test:once'",
    "release-notes": "npm --prefix server run release-notes --",
    "cli": "npx ts-node server/lib/cli/index.ts",
    "push": "bash tools/git-push.sh"
  },
  "cacheDirectories": [
    "node_modules",
    "server/node_modules"
  ],
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/platform-browser": "21.2.4",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@angular/router": "21.2.4",
    "@bluehalo/ngx-leaflet": "21.0.0",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/fontawesome-free": "6.7.2",
    "@fortawesome/fontawesome-svg-core": "6.7.2",
    "@fortawesome/free-brands-svg-icons": "6.7.2",
    "@fortawesome/free-solid-svg-icons": "6.7.2",
    "@iconify-json/logos": "1.2.10",
    "@ng-select/ng-select": "21.5.2",
    "@popperjs/core": "2.11.8",
    "@primeuix/styled": "0.7.4",
    "@primeuix/styles": "1.2.5",
    "@primeuix/utils": "0.6.3",
    "@types/luxon": "3.7.1",
    "@yaireo/tagify": "4.35.6",
    "bootstrap": "5.3.8",
    "chart.js": "4.5.1",
    "core-js": "3.47.0",
    "csv-parse": "6.1.0",
    "es-toolkit": "1.43.0",
    "hammerjs": "2.0.8",
    "he": "1.2.0",
    "heic2any": "0.0.4",
    "js-yaml": "3.13.1",
    "json2csv": "4.5.4",
    "jsonc-parser": "3.3.1",
    "leaflet": "1.9.4",
    "leaflet.markercluster": "1.5.3",
    "luxon": "3.7.2",
    "marked": "17.0.4",
    "meetup-api": "1.4.39",
    "mermaid": "11.12.2",
    "method-override": "3.0.0",
    "mongoose": "8.17.1",
    "ng-gallery": "11.0.0",
    "ng-recaptcha-2": "21.0.1",
    "ng2-charts": "10.0.0",
    "ng2-file-upload": "9.0.0",
    "ngx-bootstrap": "21.0.1",
    "ngx-capture": "0.13.0",
    "ngx-google-analytics": "14.0.1",
    "ngx-image-cropper": "6.2.2",
    "ngx-logger": "5.0.12",
    "ngx-markdown": "21.1.0",
    "ngx-tagify": "15.0.5",
    "ngx-ui-switch": "15.0.0",
    "primeicons": "7.0.0",
    "primeng": "21.1.3",
    "proj4": "2.11.0",
    "proj4leaflet": "1.0.2",
    "rxjs": "7.8.2",
    "server": "1.0.41",
    "turndown": "7.2.2",
    "url-polyfill": "1.1.14",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "@angular/language-service": "21.2.4",
    "@annix/claude-swarm": "0.1.18",
    "@types/jasminewd2": "2.0.13",
    "@types/leaflet": "1.9.21",
    "@types/marked": "4.3.2",
    "@types/turndown": "5.0.6",
    "@types/ws": "8.18.1",
    "angular-eslint": "21.3.0",
    "eslint": "9.39.2",
    "file-loader": "6.2.0",
    "jiti": "1.21.7",
    "source-map-explorer": "2.5.3",
    "ts-node": "10.9.2",
    "type-fest": "5.4.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.51.0",
    "vitest": "^4.0.8",
    "jsdom": "^26.1.0",
    "webpack": "5.105.2",
    "webpack-bundle-analyzer": "3.6.0",
    "winston": "3.19.0"
  },
  "engines": {
    "node": "v24.14.0",
    "npm": "11.9.0"
  }
}
