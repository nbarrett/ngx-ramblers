{
  "name": "ngx-ramblers",
  "description": "Server application to support ngx-ramblers application",
  "version": "3.0.0",
  "license": "ISC",
  "private": true,
  "scripts": {
    "build": "npm run clean-ts && npm run tsc && npm run copy-assets",
    "clean": "rimraf target/site/serenity",
    "clean-node": "rm -rf node_modules",
    "clean-ts": "rimraf ts-gen",
    "copy-assets": "cp -r lib/geojson ts-gen/server/lib/ && cp lib/mongo/migrations/README.md ts-gen/server/lib/mongo/migrations/database/ && cp lib/cloudflare/worker-templates/*.ts ts-gen/server/lib/cloudflare/worker-templates/",
    "deploy": "ts-node deploy/deploy-to-environments.ts",
    "cli": "tsx lib/cli/index.ts",
    "mongo-cli": "tsx deploy/mongo-cli.ts",
    "mongo-cli:interactive": "tsx deploy/mongo-cli-interactive.ts",
    "mongo:backup": "tsx deploy/mongo-cli.ts backup",
    "mongo:restore": "tsx deploy/mongo-cli.ts restore",
    "release-notes": "tsx lib/release-notes/generate-release-notes.ts",
    "release-notes:delete-pages": "tsx lib/release-notes/delete-pages.ts",
    "release-notes:refresh-build-links": "tsx lib/release-notes/refresh-build-links.ts",
    "migrate": "migrate-mongo up -f migrations/migrate-mongo-config.ts",
    "migrate:create": "migrate-mongo create -f migrations/migrate-mongo-config.ts",
    "migrate:down": "migrate-mongo down -f migrations/migrate-mongo-config.ts",
    "check:shai-hulud": "tsx deploy/check-shai-hulud.ts",
    "migrate:mark-old-applied": "ts-node lib/mongo/migrations/mark-migrations-applied.ts",
    "migrate:status": "migrate-mongo status -f migrations/migrate-mongo-config.ts",
    "postinstall": "tsc && npm run copy-assets",
    "reinstall": "npm run clean-node && npm install",
    "report": "serenity-bdd run --features lib/serenity-js/features",
    "serenity": "failsafe clean serenity-run report",
    "serenity-bdd-update": "serenity-bdd update --ignoreSSL",
    "serenity-run": "playwright test -c ./playwright.config.ts",
    "server": "node ts-gen/server/lib/server",
    "worker-server": "node --max_old_space_size=384 ts-gen/server/lib/ramblers/integration-worker-server",
    "worker-server-live": "node --import tsx --watch-path=lib lib/ramblers/integration-worker-server",
    "server-live": "node --import tsx --watch-path=lib lib/server",
    "tsc": "tsc --project ./tsconfig.json",
    "tsc-check": "tsc --project ./tsconfig.json --noEmit",
    "tsc-watch": "tsc --project ./tsconfig.json --watch",
    "unit-test": ". test-setenv.sh && npm run build && mocha --watch",
    "unit-test:once": "bash -lc 'source ./test-setenv.sh && npm run build && mocha'",
    "test:serenity-discovery": "playwright test --list -c ./playwright.config.ts"
  },
  "nodemonConfig": {
    "ignore": [
      "*.log",
      "target/**/*"
    ]
  },
