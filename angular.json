{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngx-ramblers": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "sass"
        },
        "@schematics/angular:application": {
          "strict": true
        }
      },
      "root": "projects/ngx-ramblers",
      "sourceRoot": "projects/ngx-ramblers/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "allowedCommonJsDependencies": [
              "@yaireo/tagify",
              "html2canvas",
              "leaflet",
              "leaflet.markercluster",
              "lodash",
              "moment-timezone",
              "mongoose"
            ],
            "outputPath": {
              "base": "dist/ngx-ramblers",
              "browser": ""
            },
            "index": "projects/ngx-ramblers/src/index.html",
            "polyfills": [
              "projects/ngx-ramblers/src/polyfills.ts"
            ],
            "tsConfig": "projects/ngx-ramblers/tsconfig.app.json",
            "inlineStyleLanguage": "sass",
            "assets": [
              "projects/ngx-ramblers/src/favicon.ico",
              {
                "input": "projects/ngx-ramblers/src/app/assets",
                "glob": "**/**/*.*",
                "output": "/assets"
              },
              {
                "glob": "*.png",
                "input": "node_modules/leaflet/dist/images",
                "output": "/media/assets/images"
              },
              {
                "glob": "*.png",
                "input": "node_modules/leaflet/dist/images",
                "output": "/assets/images"
              }
            ],
            "styles": [
              "projects/ngx-ramblers/src/app/assets/styles/styles.sass",
              "node_modules/leaflet/dist/leaflet.css",
              "node_modules/leaflet.markercluster/dist/MarkerCluster.css",
              "node_modules/leaflet.markercluster/dist/MarkerCluster.Default.css"
            ],
            "browser": "projects/ngx-ramblers/src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10mb",
                  "maximumError": "12mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "512kb",
                  "maximumError": "1024kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ngx-ramblers/src/environments/environment.ts",
                  "with": "projects/ngx-ramblers/src/environments/environment.production.ts"
                }
              ],
              "optimization": {
                "styles": {
                  "inlineCritical": false
                }
              },
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": {
                "scripts": false,
                "styles": true,
                "vendor": false
              },
              "namedChunks": true,
              "verbose": false
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "projects/ngx-ramblers/proxy.config.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "ngx-ramblers:build:production"
            },
            "development": {
              "buildTarget": "ngx-ramblers:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "ngx-ramblers:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "ngx-ramblers:build:development",
            "tsConfig": "projects/ngx-ramblers/tsconfig.spec.json",
            "runner": "vitest",
            "setupFiles": [
              "projects/ngx-ramblers/src/test-setup.ts"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngx-ramblers/**/*.ts",
              "projects/ngx-ramblers/**/*.html"
            ],
            "eslintConfig": ".eslint-config/projects/ngx-ramblers/eslint.config.js"
          }
        }
      }
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "style": "sass"
    }
  },
  "cli": {
    "analytics": "2bb37b0d-21c6-47ef-b513-a7c5a141a02c",
    "schematicCollections": [
      "angular-eslint"
    ]
  }
}
